generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(backlog)
  priority    TaskPriority @default(medium)
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
}

model Content {
  id          String       @id @default(cuid())
  title       String
  body        String
  type        ContentType
  status      ContentStatus @default(draft)
  authorId    String
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([authorId])
}

model Memory {
  id        String     @id @default(cuid())
  content   String
  type      MemoryType
  source    String?
  embedding Float[]?
  metadata  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([type])
}

enum TaskStatus {
  backlog
  todo
  in_progress
  done
  archived
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum ContentType {
  post
  doc
  note
  page
}

enum ContentStatus {
  draft
  review
  published
  archived
}

enum MemoryType {
  conversation
  document
  observation
  insight
}
