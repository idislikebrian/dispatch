generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  workspaces   Workspace[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Workspace {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  logEntries LogEntry[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([ownerId])
}

model LogEntry {
  id          String   @id @default(cuid())
  type        String   // e.g., "info", "warn", "error"
  message     String
  metadata    Json?    // flexible JSON for future data
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([createdAt])
}

// ─── Agent Telemetry ────────────────────────────────────────────────────────

enum Project {
  Cobalt
  Caminos
  HIGHER
  Aluminum
  Experimental
}

model Agent {
  id          String            @id @default(cuid())
  name        String            @unique
  type        String            // e.g. "openclaw", "subagent", "cron"
  project     Project?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  heartbeats  AgentHeartbeat[]
  events      AgentEvent[]
  costEvents  AgentCostEvent[]
  interrupts  AgentInterrupt[]

  @@index([project])
}

model AgentHeartbeat {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status    String   // "online", "idle", "offline", "error"
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([agentId, createdAt])
}

model AgentEvent {
  id        String          @id @default(cuid())
  agentId   String
  agent     Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type      String          // "action", "error", "info", "warning"
  message   String
  project   Project?
  metadata  Json?
  costEvent AgentCostEvent?
  content   ContentItem[]
  createdAt DateTime        @default(now())

  @@index([agentId])
  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([project])
}

model AgentCostEvent {
  id           String      @id @default(cuid())
  agentId      String
  agent        Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  eventId      String?     @unique
  event        AgentEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  model        String      // e.g. "claude-sonnet-4", "gpt-4o"
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  project      Project?
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([agentId])
  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([project])
}

model AgentInterrupt {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type      String   // "pause", "resume", "stop", "custom"
  message   String?
  status    String   @default("pending") // "pending", "delivered", "acknowledged"
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([agentId, status])
}

// ─── Content Pipeline ───────────────────────────────────────────────────────

enum ContentPlatform {
  substack
  warpcast
  threads
  bluesky
  youtube
  instagram
  other
}

enum ContentStage {
  idea
  draft
  editing
  scheduled
  published
  repurposed
  archived
}

enum OwnerType {
  human
  agent
}

model ContentItem {
  id             String          @id @default(cuid())
  title          String
  project        Project
  platform       ContentPlatform
  stage          ContentStage
  ownerName      String
  ownerType      OwnerType
  summary        String?
  sourceIdea     String?
  relatedEventId String?
  relatedEvent   AgentEvent?     @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)
  scheduledFor   DateTime?
  publishedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([project])
  @@index([stage])
  @@index([platform])
  @@index([ownerName])
  @@index([createdAt(sort: Desc)])
  @@index([project, stage])
  @@index([relatedEventId])
}
